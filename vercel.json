{
    "version": 2,
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/upload",
            "destination": "server.js"
        },
        {
            "source": "/",
            "destination": "/public/index.html"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "/public/$1"
        },
        { "source": "/register", "destination": "/public/register.html" },
        { "source": "/user/:id/record", "destination": "/public/record.html" }
    ]
}